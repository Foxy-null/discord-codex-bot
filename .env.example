# Discord Botのトークン
# Discord Developer Portalで取得: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# 作業ディレクトリのベースパス
# リポジトリのクローン、ログ、セッション情報などが保存される場所
# .env 内の ~ は展開されないため、絶対パスで指定してください
WORK_BASE_DIR=/absolute/path/to/codex-bot-work

# Codex実行時に追加するシステムプロンプト（オプション）
# Codexの動作をカスタマイズしたい場合に使用
# CODEX_APPEND_SYSTEM_PROMPT="あなたは日本語で応答します"

# /status と最終行に表示する Codex limit reset 時刻のタイムゾーン
CODEX_STATUS_TIME_ZONE=Asia/Tokyo

# OpenAI Costs API の集計に使う管理キー（任意）
# 未設定の場合はコスト集計は pending のままになります
# OPENAI_ADMIN_KEY=your_openai_admin_key_here
